# Codex Legalis — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to version control.
#
# IMPORTANT: Rotate your API key if it has been exposed.
# Consider adding a pre-commit hook (e.g., gitleaks, detect-secrets)
# to prevent accidental secret commits.

QWEN_API_KEY=your-api-key-here

# Optional: alternative key name accepted by the audio module.
# DASHSCOPE_API_KEY is an alias for QWEN_API_KEY — either one works.
# DASHSCOPE_API_KEY=your-dashscope-key

# Optional: audio transcription model (single model).
# Valid models: qwen-omni-turbo, qwen3-omni-flash, qwen3-omni,
#               qwen-audio-turbo, qwen2-audio-7b-instruct
# QWEN_AUDIO_MODEL=qwen-omni-turbo

# Optional: audio transcription fallback chain (comma-separated).
# The system tries each model in order until one succeeds.
# QWEN_AUDIO_MODELS=qwen-omni-turbo,qwen3-omni-flash,qwen-audio-turbo

# Optional: TTS model and voice.
# QWEN_TTS_MODEL=qwen3-tts-flash
# QWEN_TTS_VOICE=Cherry
# Valid voices: Cherry, Serena, Ethan, Chloe
