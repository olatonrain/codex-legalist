# Codex Legalis — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to version control.

QWEN_API_KEY=your-api-key-here

# Optional: alternative key name accepted by the audio module
# DASHSCOPE_API_KEY=your-dashscope-key

# Optional: audio transcription model (single model)
# QWEN_AUDIO_MODEL=qwen-omni-turbo

# Optional: audio transcription fallback chain (comma-separated)
# QWEN_AUDIO_MODELS=qwen-omni-turbo,qwen3-omni-flash,qwen-audio-turbo

# Optional: TTS model and voice
# QWEN_TTS_MODEL=qwen3-tts-flash
# QWEN_TTS_VOICE=Cherry
